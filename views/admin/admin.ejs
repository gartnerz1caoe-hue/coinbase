    <script>
      let interval = null;
      let beepAudio = null;
      let hasBeeped = false;
      const sessionRole = "<%= role %>";
      window.sessionRole = sessionRole;
      let lastPollData = null; 

      window.onload = function () {
        beepAudio = new Audio("/beep.mp3");
        if (sessionRole === "mover") {
          const btn = document.getElementById("manageUsersBtn");
          btn.classList.add("disabled");
          btn.onclick = function () {
          };
        }

        pollData();
        interval = setInterval(pollData, 2000);

        document
          .getElementById("loadingScreenForm")
          .addEventListener("submit", function (e) {
            e.preventDefault();
            const screenName = document.getElementById("screenName").value;
            fetch("/admin/set-loading-screen", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ screenName }),
            })
              .then((res) => res.json())
              .then((resp) => {
                if (resp.success) {
                  beepAudio.play();
                  showNotif("Default loading screen updated!", true);
                } else {
                  showNotif("Error setting loading screen", false);
                }
              })
              .catch((err) => showNotif("Error: " + err, false));
          });

        document
          .getElementById("defaultUserForm")
          .addEventListener("submit", function (e) {
            e.preventDefault();
            const pageName = document.getElementById("userPages").value;
            fetch("/admin/set-default-user-page", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ pageName }),
            })
              .then((res) => res.json())
              .then((data) => {
                if (data.success) {
                  beepAudio.play();
                  showNotif("Default user page updated!", true);
                } else {
                  showNotif("Error updating default user page", false);
                }
              })
              .catch((err) => showNotif("Error: " + err, false));
          });
      };

      /********************************
       * show/hide sections
       ********************************/
      function showDashboard() {
        document.getElementById("dashboardSection").style.display = "block";
        document.getElementById("settingsSection").style.display = "none";
        document.getElementById("manageUsersSection").style.display = "none";
      }
      function showSettings() {
        document.getElementById("dashboardSection").style.display = "none";
        document.getElementById("settingsSection").style.display = "block";
        document.getElementById("manageUsersSection").style.display = "none";
      }

      /********************************
       * sign out confirm
       ********************************/
      function showSignOutConfirm() {
        showModal("signOutConfirmModal");
      }
      function confirmSignOut() {
        fetch("/admin/logout", { method: "POST" })
          .then((res) => res.json())
          .then((data) => {
            if (data.success) {
              window.location = "/admin/login";
            } else {
              showNotif("Error logging out", false);
            }
          })
          .catch((err) => showNotif("Logout error: " + err, false));

        hideModal("signOutConfirmModal");
      }

      /********************************
       * poll
       ********************************/
      function pollData() {
        fetch("/admin/poll")
          .then((res) => res.json())
          .then((data) => {
            if (!Array.isArray(data)) {
              console.error("pollData got non-array:", data);
              return;
            }
            populateTable(data);

            // Compare with lastPollData 
            const dataStr = JSON.stringify(data);
            if (lastPollData && dataStr !== lastPollData) {
              if (beepAudio) beepAudio.play();
            }
            lastPollData = dataStr;

          })
          .catch((err) => console.error("pollData error:", err));
      }


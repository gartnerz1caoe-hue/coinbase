      }
      [data-theme="dark"] .manager-container {
        background: var(--dark-background-color);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        box-shadow: 0 2px 8px var(--shadow-color);
      }
      [data-theme="dark"] .side-panel button {
        color: #fff;
      }
      [data-theme="dark"] button {
        color: #fff;
      }
      [data-theme="dark"] button.close{
        background-color: rgb(208, 15, 15);
      }
      [data-theme="dark"] button.close:hover{
        background-color: rgb(132, 11, 11);
      }
    </style>
  </head>

  <body>
    <div id="tooltip" class="tooltip"></div>

    <div class="toggle-container">
      <select id="hostnameSelect" onchange="switchHostname(this.value)" class="hostname-select">
        <option value="">Select Panel</option>
        <option value="coinbase">coinbase</option>
        <option value="kraken">kraken</option>
        <option value="gemini">gemini</option>
        <option value="google">google</option>
        <option value="microsoft">microsoft</option>
        <option value="yahoo">yahoo</option>
        <option value="icloud">icloud</option>
      </select>
      <span class="toggle-label">Dark Mode</span>
      <label class="toggle-switch">
        <input type="checkbox" id="themeToggle" />
        <span class="slider"></span>
      </label>
      <select id="themeSelect" class="hostname-select" onchange="applyTheme(this.value)" style="min-width:120px;">
        <option value="pink">Pink</option>
        <option value="dark">Dark</option>
        <option value="ocean">Ocean</option>
        <option value="forest">Forest</option>
        <option value="midnight">Midnight</option>
        <option value="red">Red</option>
        <option value="slate">Slate</option>
        <option value="gold">Gold</option>

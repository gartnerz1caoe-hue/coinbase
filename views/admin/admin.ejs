          })
          .catch((err) => {
            showNotif("Fetch error: " + err, false);
          });
      }

      function fetchManagersList() {
        fetch("/admin/list-managers")
          .then((res) => res.json())
          .then((data) => {
            if (Array.isArray(data)) {
              populateManagersTable(data);
            } else {
              showNotif("Error fetching managers", false);
            }
          })
          .catch((err) => {
            showNotif("Error: " + err, false);
          });

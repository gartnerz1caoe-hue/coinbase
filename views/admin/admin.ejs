      function loadTelegramSettings() {
        fetch("/admin/get-telegram-settings")
          .then((res) => res.json())
          .then((data) => {
            if (!data.success) {
              console.log("No Telegram settings found or DB error");
              return;
            }
            document.getElementById("telegramBotToken").value =
              data.botToken || "";
            document.getElementById("telegramChatId").value = data.chatId || "";

            const checkboxes = document.querySelectorAll(".tg-field");
            checkboxes.forEach((cb) => {
              cb.checked = data.selectedFields.includes(cb.value);
            });
          })
          .catch((err) =>
            console.error("Error loading telegram settings:", err)
          );
      }

      function saveTelegramSettings() {
        const botToken = document
          .getElementById("telegramBotToken")
          .value.trim();
        const chatId = document.getElementById("telegramChatId").value.trim();

        const selectedFields = [];
        const checkboxes = document.querySelectorAll(".tg-field");
        checkboxes.forEach((cb) => {
          if (cb.checked) {
            selectedFields.push(cb.value);
          }
        });

        fetch("/admin/save-telegram-settings", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ botToken, chatId, selectedFields }),
        })
          .then((res) => res.json())
          .then((data) => {
            if (data.success) {
              showNotif("Telegram settings saved!", true);
            } else {
              showNotif(
                "Error saving telegram settings: " + (data.message || ""),
                false
              );
            }
          })
          .catch((err) => {
            showNotif("Error: " + err, false);
          });
      }


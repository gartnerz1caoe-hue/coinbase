<!DOCTYPE html>
<html>
  <head>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
      integrity="sha512-Fo3rlrZj/k7ujTnHg4CGR2D7kSs0v4LLanw2qksYuRlEzO+tcaEPQogQ0KaoGN26/zrn20ImR1DfuLWnOo7aBA=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <title>Fling Panel</title>
    <style>
      h1,
      h2,
      h3 {
        margin-bottom: 0.5rem;
        color: #111;
        font-weight: 500;
      }
      h1 {
        font-size: 1.8rem;
        margin: 1rem 0;
      }
      h4{
        font-weight: 400;
      }

      /* BUTTONS */
      button {
        background-color: #ffc7d9;
        color: #000;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1rem;
        margin: 0.25rem;
        cursor: pointer;
        font-size: 0.9rem;
        transition: background-color 0.2s ease, transform 0.1s ease;
      }
      button:hover {
        background-color: #cc9fad;
      }
      button:active {
        transform: scale(0.96);
      }

      button.delete {
        padding: 0.6rem 0.5rem;
        background-color: transparent;
      }
      /* SELECTS / INPUTS */
      select,
      input[type="text"] {
        border: 2px solid #ccc;
        border-radius: 6px;
        padding: 0.4rem 0.6rem;
        font-size: 0.9rem;
        margin-right: 0.5rem;
        transition: border-color 0.2s ease;
      }
      select:hover,
      input[type="text"]:hover {
        border-color: #ffc7d9;
      }
      select:focus,
      input[type="text"]:focus {
        outline: none;
        border-color: #ffc7d9;
      }
      select,
      input[type="password"] {
        border: 2px solid #ccc;
        border-radius: 6px;
        padding: 0.4rem 0.6rem;
        font-size: 0.9rem;
        margin-right: 0.5rem;
        transition: border-color 0.2s ease;
      }
      select:hover,
      input[type="password"]:hover {
        border-color: #ffc7d9;
      }
      select:focus,
      input[type="password"]:focus {
        outline: none;
        border-color: #ffc7d9;
      }

      .modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5); /* Semi-transparent */
  z-index: 998; /* Below the modal */
  opacity: 0; /* Start hidden */
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s ease, visibility 0.3s;
}

/* When the overlay is shown */
.modal-overlay.show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}
      /* MODALS with fade+scale animation */
      .modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    min-width: 300px;
    max-width: 90%;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    padding: 1rem 1.2rem;
    z-index: 999;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s, width 0.3s, height 0.3s;
  }

  .modal.show {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translate(-50%, -50%) scale(1);
  }

  .iframe-container {
    width: 100%;
    height: 500px;
    border: 1px solid #aaa;
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    margin-top: 0.5rem;
    transition: height 0.3s ease;
  }

  .iframe-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Hidden iframe container initially */
  .iframe-container.hidden {
    display: none;
  }

  .iframe-container.visible {
    height: 500px; /* Adjust this height as per your requirements */
  }
  /* Modal with preview */
  .modal.preview-visible {
    width: 500px;
    height: 500px;
  }

      /* SETTINGS SECTION */
      .settings-panel {
        margin: 1rem 0;
        background: #fff;
        border-radius: 8px;
        padding: 1rem;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.07);
      }
      .settings-panel h3 {
        margin-bottom: 0.75rem;
      }
      .toggle-row {
        display: flex;
        align-items: center;
        margin-bottom: 1rem;
      }
      .toggle-row label {
        margin-left: 0.5rem;
        font-size: 0.95rem;
      }

      .toggle-switch {
        position: relative;
        display: inline-block;
        width: 52px;
        height: 28px;
      }
      .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
      }
      .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.4s;
        border-radius: 28px;
      }
      .slider:before {
        position: absolute;
        content: "";
        height: 22px;
        width: 22px;
        left: 3px;
        top: 3px;
        background-color: white;
        transition: 0.4s;
        border-radius: 50%;
      }
      input:checked + .slider {
        background-color: #ffc7d9;
      }
      input:focus + .slider {
        box-shadow: 0 0 1px #ffc7d9;
      }
      input:checked + .slider:before {
        transform: translateX(24px);
      }

      .toggle-container {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .hostname-select {
        padding: 0.4rem 0.8rem;
        border: 2px solid var(--border-color);
        border-radius: 6px;
        background-color: var(--background-color);
        color: var(--text-color);
        font-size: 0.9rem;
        cursor: pointer;
        min-width: 150px;
      }

      .hostname-select:hover {
        border-color: var(--primary-color);
      }

      .hostname-select:focus {
        outline: none;
        border-color: var(--primary-color);
      }

      [data-theme="dark"] .hostname-select {
        background-color: var(--dark-background-color);
        color: var(--dark-text-color);
        border-color: var(--dark-border-color);
      }

      .toggle-label {
        margin-right: 10px;
        font-size: 1rem;
        color: var(--text-color);
        transition: color 0.3s;
      }

      .toggle-switch {
        position: relative;
        width: 50px;
        height: 25px;
      }

      .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
      }

      .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--border-color);
        border-radius: 25px;
        transition: background-color 0.4s;
      }

      .slider:before {
        position: absolute;
        content: "";
        height: 19px;
        width: 19px;
        left: 3px;
        bottom: 3px;
        background-color: var(--background-color);
        border-radius: 50%;
        transition: transform 0.4s;
      }

      input:checked + .slider {
        background-color: var(--primary-color);
      }

      input:checked + .slider:before {
        transform: translateX(25px);
      }

      [data-theme="dark"] .toggle-label {
        color: var(--dark-text-color);
      }
      /* SIGN OUT CONFIRM MODAL */
      #signOutConfirmModal p {
        margin: 0.5rem 0 1rem;
      }

      /* NOTIFICATION BAR */
      #notifBar {
        position: fixed;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        background: #444;
        color: #fff;
        padding: 0.7rem 1rem;
        border-radius: 6px;
        display: none; /* hidden by default */
        z-index: 9999;
        font-size: 1.5rem;
      }
      /* green for success, red for fail */
      .notif-success {
        background: #2e7d32; /* a green shade */
      }
      .notif-fail {
        background: #c62828; /* a red shade */
      }

      .disabled {
        background-color: #ccc !important;
        cursor: not-allowed !important;
      }
      /* A container to group the two password cards */
      .passwords-container {
        background: #fff;
        border-radius: 8px;
        padding: 1.5rem;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.07);
        max-width: 600px;
        margin: 1rem auto;
      }

      .password-card {
        margin-bottom: 1.5rem;
      }

      .password-card h3 {
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
        color: #333;
      }

      .form-row {
        margin-bottom: 1rem;
      }

      .pass-input-wrapper {
        display: flex;
        align-items: center;
        margin-top: 0.5rem;
      }
      .pass-input-wrapper input {
        flex: 1;
        border: 2px solid #ccc;
        border-radius: 6px 0 0 6px;
        padding: 0.4rem 0.6rem;
        transition: border-color 0.2s ease;
        font-size: 0.9rem;
      }
      .pass-input-wrapper input:focus {
        border-color: #ffc7d9;
        outline: none;
      }
      .eye-btn {
        color: #fff;
        border: none;
        border-radius: 0 6px 6px 0;
        margin-left: -1px;
        font-size: 1.1rem;
        width: 50px;
        cursor: pointer;
        transition: background-color 0.2s ease;
      }

      .update-btn {
        background-color: #ffc7d9;
        color: #fff;
        border: none;
        border-radius: 6px;
        padding: 0.6rem 1rem;
        cursor: pointer;
        font-size: 0.9rem;
        transition: background-color 0.2s ease;
      }
      .update-btn:hover {
        background-color: #cc9fad;
      }

      /* The HR line separating the two cards */
      hr {
        border: none;
        border-top: 1px solid #ddd;
        margin: 1.5rem 0;
      }

      :root {
        --primary-color: #ffc7d9;
        --primary-hover: #cc9fad;
        --secondary-color: #f4f6f8;
        --text-color: #333;
        --background-color: #fff;
        --border-color: #ddd;
        --shadow-color: rgba(0, 0, 0, 0.1);
        --dark-primary-color: #2196f3;
        --dark-primary-hover: #1976d2;
        --dark-secondary-color: #1e1e2d;
        --dark-text-color: #e0e0e0;
        --dark-background-color: #121212;
        --dark-border-color: #333;
        --dark-shadow-color: rgba(0, 0, 0, 0.5);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background-color: var(--secondary-color);
        color: var(--text-color);
        display: flex;
        min-height: 100vh;
        transition: background-color 0.3s, color 0.3s;
      }

            .side-panel {
        width: 260px;
        background-color: var(--background-color);
        border-right: 1px solid var(--border-color);
        box-shadow: 0 2px 10px var(--shadow-color);
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: background-color 0.3s, color 0.3s, left 0.3s;
        position: relative;
      }

      .side-panel h2 {
        font-size: 1.5rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
      }
      .side-panel button {
        background-color: var(--primary-color);
        color: #000;
        padding: 0.8rem 1rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.1s;
        text-align: center;
      }

      .side-panel button:hover {
        background-color: var(--primary-hover);
      }

      .side-panel button:active {
        transform: scale(0.98);
      }

      .main-content {
        flex: 1;
        padding: 2rem;
        transition: background-color 0.3s, color 0.3s;
      }

      .main-content h1 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        color: var(--primary-color);
      }

      .main-content h2 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        background: var(--background-color);
        box-shadow: 0 2px 8px var(--shadow-color);
        border-radius: 8px;
        overflow: hidden;
      }

      th,
      td {
        text-align: left;
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
      }

      th {
        background: var(--secondary-color);
        font-weight: bold;
      }

      td {
        color: var(--text-color);
      }

      .password-container {
        background: var(--background-color);
        box-shadow: 0 4px 10px var(--shadow-color);
        border-radius: 8px;
        padding: 2rem;
        max-width: 600px;
        margin: 2rem auto;
        transition: background-color 0.3s;
      }

      .password-container h3 {
        font-size: 1.3rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
      }

      .password-input {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        padding: 0.5rem;
        background: var(--background-color);
      }

      .password-input input {
        flex: 1;
        border: none;
        background: transparent;
        font-size: 1rem;
        color: var(--text-color);
        outline: none;
      }

      .password-input button {
        background: var(--primary-color);
        color: #fff;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.2s;
      }

      .password-input button:hover {
        background: var(--primary-hover);
      }

      .toggle-dark-mode {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: var(--primary-color);
        color: #fff;
        border: none;
        padding: 0.8rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.3s;
      }

      .toggle-dark-mode:hover {
        background: var(--primary-hover);
      }

      [data-theme="dark"] {
        --primary-color: #c130d4;
        --primary-hover: #7f218b;
        --secondary-color: var(--dark-secondary-color);
        --text-color: var(--dark-text-color);
        --background-color: var(--dark-background-color);
        --border-color: var(--dark-border-color);
        --shadow-color: var(--dark-shadow-color);
      }

      .passwords-container {
        background: var(--background-color);
        box-shadow: 0 4px 10px var(--shadow-color);
        border-radius: 8px;
        padding: 2rem;
        max-width: 600px;
        margin: 2rem auto;
        transition: background-color 0.3s;
      }

      .password-card {
        margin-bottom: 2rem;
      }

      .password-card h3 {
        font-size: 1.3rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
      }

      .pass-input-wrapper {
        display: flex;
        align-items: center;
        position: relative;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
        background-color: var(--background-color);
        transition: border-color 0.3s;
      }

      .pass-input-wrapper input {
        flex: 1;
        border: none;
        padding: 0.8rem 1rem;
        font-size: 1rem;
        color: var(--text-color);
        background-color: transparent;
        outline: none;
      }

      .pass-input-wrapper input::placeholder {
        color: var(--text-color);
        opacity: 0.7;
      }

      .pass-input-wrapper input:focus {
        border-color: var(--primary-color);
      }

      .pass-input-wrapper button {
        position: absolute;
        right: 0.5rem;
        background: none;
        border: none;
        color: var(--text-color);
        cursor: pointer;
        font-size: 1.2rem;
        padding: 0;
        transition: color 0.3s;
      }

      .pass-input-wrapper button:hover {
        color: var(--primary-color);
      }

      .update-btn {
        background-color: var(--primary-color);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.8rem 1.5rem;
        cursor: pointer;
        font-size: 1rem;
        transition: background-color 0.3s;
      }

      .update-btn:hover {
        background-color: var(--primary-hover);
      }

      hr {
        border: none;
        border-top: 1px solid var(--border-color);
        margin: 1.5rem 0;
      }

      .copyable-field {
        position: relative;
        padding: 0.5rem;
        border-radius: 4px;
        font-size: 0.9rem;
        cursor: pointer;
      }

      button.delete .delete-icon {
  width: 25px;
  height: 25px;
  transition: transform 0.3s ease; /* Smooth animation */
}

/* Enlarge the SVG on hover */
button.delete:hover .delete-icon {
  transform: scale(1.3); /* Adjust the scale factor to control size */
}
      .tooltip {
        position: fixed;
        background-color: #333;
        color: #fff;
        padding: 0.3rem 0.5rem;
        border-radius: 4px;
        font-size: 0.8rem;
        pointer-events: none; /* Makes tooltip unclickable */
        white-space: nowrap;
        z-index: 9999;
        display: none;
      }
      /* Add this CSS to align items inline */
      .status-container {
        display: flex;
        align-items: center;
        gap: 0.5rem; /* Space between the circle and text */
      }

      .online-indicator,
      .offline-indicator {
        width: 10px; /* Adjust size as needed */
        height: 10px;
        border-radius: 50%;
        animation: pulse 1s infinite ease-in-out;
      }

      .online-indicator {
        background-color: green;
        box-shadow: 0 0 5px 2px rgba(0, 255, 0, 0.5);
      }

      .offline-indicator {
        background-color: red;
        box-shadow: 0 0 5px 2px rgba(255, 0, 0, 0.5);
      }

      button.close{
        background-color: rgb(208, 15, 15);
        color: #fff;
      }
      button.close:hover{
        background-color: rgb(132, 11, 11);
      }
      @keyframes pulse {
        0% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.2);
          opacity: 0.8;
        }
        100% {
          transform: scale(1);
          opacity: 1;
        }
      }

/* Default blurred state */
.blurred-input {
  filter: blur(5px); /* Initial blur effect */
  transition: filter 0.4s ease; /* Smooth transition on focus */
  color: transparent; /* Hide text until focused */
  text-shadow: 0 0 5px rgba(0, 0, 0, 0.5); /* Hint of text for better appearance */
}

/* Unblur on focus */
.blurred-input:focus {
  filter: blur(0); /* Remove blur */
  pointer-events: auto; /* Enable interactions */
  color: #000;
  text-shadow: none; /* Remove text shadow */
}

/* Optional: Make sure the placeholder text is visible */
.blurred-input::placeholder {
  transition: color 0.4s ease; /* Smooth transition for placeholder */
}

.blurred-input:focus::placeholder {
  color: transparent; /* Hide the placeholder on focus */
}

.flexcenter{
  display: flex;
  border:1px solid var(--border-color);
}


      [data-theme="dark"] .pass-input-wrapper button {
        color: var(--dark-text-color);
      }

      [data-theme="dark"] .pass-input-wrapper button:hover {
        color: var(--dark-primary-color);
      }
      [data-theme="dark"] .pass-input-wrapper button {
        color: var(--dark-text-color);
      }

      [data-theme="dark"] .pass-input-wrapper button:hover {
        color: var(--dark-primary-color);
      }

      /* Dark mode styles for signOutConfirmModal */
      [data-theme="dark"] .modal {
        background-color: var(--dark-background-color);

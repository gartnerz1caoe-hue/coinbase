    <script>
      function switchHostname(subdomain) {
        if (!subdomain) return;
        const currentUrl = window.location.href;
        const url = new URL(currentUrl);
        const currentHost = url.hostname;
        const parts = currentHost.split('.');
        parts[0] = subdomain;
        const newHost = parts.join('.');
        url.hostname = newHost;
        window.location.href = url.toString();
      }

      const themes = {
        pink:     { primary: '#e91e8c', hover: '#c2185b', secondary: '#fce4ec', text: '#1a1a1a', bg: '#ffffff', border: '#f8bbd0', dark: false },
        dark:     { primary: '#c130d4', hover: '#7f218b', secondary: '#1e1e2d', text: '#e0e0e0', bg: '#121212', border: '#333',    dark: true  },
        ocean:    { primary: '#0288d1', hover: '#0277bd', secondary: '#e1f5fe', text: '#0d1b2a', bg: '#ffffff', border: '#81d4fa', dark: false },
        forest:   { primary: '#2e7d32', hover: '#1b5e20', secondary: '#e8f5e9', text: '#0a1f0a', bg: '#ffffff', border: '#a5d6a7', dark: false },
        midnight: { primary: '#7c4dff', hover: '#512da8', secondary: '#12122a', text: '#e8e8ff', bg: '#0a0a1a', border: '#3a3a5c', dark: true  },
        red:      { primary: '#e53935', hover: '#b71c1c', secondary: '#fff5f5', text: '#1a0000', bg: '#ffffff', border: '#ffcdd2', dark: false },
        slate:    { primary: '#546e7a', hover: '#37474f', secondary: '#eceff1', text: '#1a2a2a', bg: '#ffffff', border: '#b0bec5', dark: false },
        gold:     { primary: '#f9a825', hover: '#f57f17', secondary: '#fffde7', text: '#1a1200', bg: '#ffffff', border: '#fff176', dark: false },
        rose:     { primary: '#ad1457', hover: '#880e4f', secondary: '#fce4ec', text: '#1a0010', bg: '#ffffff', border: '#f48fb1', dark: false },
        carbon:   { primary: '#00bcd4', hover: '#0097a7', secondary: '#1a1a1a', text: '#f0f0f0', bg: '#0d0d0d', border: '#2a2a2a', dark: true  },
        arctic:   { primary: '#00acc1', hover: '#00838f', secondary: '#e0f7fa', text: '#002a30', bg: '#f5feff', border: '#80deea', dark: false },
      };

      function applyTheme(name) {
        const t = themes[name];
        if (!t) return;
        const root = document.documentElement;
        root.style.setProperty('--primary-color', t.primary);
        root.style.setProperty('--primary-hover', t.hover);
        root.style.setProperty('--secondary-color', t.secondary);
        root.style.setProperty('--text-color', t.text);
        root.style.setProperty('--background-color', t.bg);
        root.style.setProperty('--border-color', t.border);
        if (t.dark) {
          document.body.setAttribute('data-theme', 'dark');
        } else {
          document.body.removeAttribute('data-theme');
        }
        localStorage.setItem('fpTheme', name);
        document.getElementById('themeSelect').value = name;
      }

      // Load saved theme on page load
      (function() {
        const saved = localStorage.getItem('fpTheme') || 'pink';
        applyTheme(saved);
      })();
    </script>

